# ── Polygon / Polymarket ──────────────────────────────────────────────────────
ALCHEMY_POLYGON_WS_URL=wss://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY

POLYMARKET_PRIVATE_KEY=0x...
POLYMARKET_API_KEY=...
POLYMARKET_API_SECRET=...
POLYMARKET_API_PASSPHRASE=...

# ── Solana ────────────────────────────────────────────────────────────────────
SOLANA_PRIVATE_KEY=...         # base58-encoded keypair
BIRDEYE_API_KEY=...

# ── OSINT ─────────────────────────────────────────────────────────────────────
NEWSAPI_API_KEY=...
REDDIT_CLIENT_ID=...
REDDIT_CLIENT_SECRET=...

# ── AI providers (pick ONE — Gemini is free) ─────────────────────────────────────────────────────────────────
LLM_PROVIDER=gemini            # gemini | anthropic | openai
EMBEDDING_PROVIDER=gemini      # gemini | openai
GEMINI_API_KEY=...             # https://aistudio.google.com/apikey (FREE)
ANTHROPIC_API_KEY=sk-ant-...   # optional — higher quality reasoning
OPENAI_API_KEY=sk-...          # optional — alternative embeddings

# ── Notifications ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...

# ── Infrastructure ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql+asyncpg://oracle:oracle@localhost:5432/oracle

# ── Storage paths ─────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma    # ChromaDB: oracle_markets + oracle_theses collections
KBPM_VAULT_DIR=./data/vault         # KBPM markdown vault: markets/ wallets/ theses/ etc.
